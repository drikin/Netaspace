# 桜環境用環境変数テンプレート

# ===== 認証設定 =====
# Replitドメイン（カンマ区切りで複数設定可能）
REPLIT_DOMAINS="your-replit-domain.replit.app,your-sakura-domain.com"

# セッション暗号化キー（32文字以上の安全な文字列）
SESSION_SECRET="your-secure-session-secret-key-here"

# 管理者ユーザーID（ReplitのユーザーID）
ADMIN_USER_ID="29156743"

# Replit OAuth設定
REPL_ID="3982670a-b0a3-4407-a7b6-ca27d6fabfdf"
ISSUER_URL="https://replit.com/oidc"

# ===== データベース設定 =====
# PostgreSQL接続URL
DATABASE_URL="postgresql://username:password@localhost:5432/backspace_fm"

# PostgreSQL個別設定
PGHOST="localhost"
PGPORT="5432"
PGUSER="backspace_user"
PGPASSWORD="your-secure-password"
PGDATABASE="backspace_fm"

# ===== アプリケーション設定 =====
# 実行環境
NODE_ENV="production"

# ポート設定（通常はDockerで自動設定）
PORT="5000"