Chrome Extension Files Package

--- manifest.json ---
{
  "manifest_version": 3,
  "name": "Backspace.fm ネタ投稿",
  "version": "1.0.0",
  "description": "現在のページをbackspace.fmのネタとして簡単に投稿できます",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.replit.dev/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Backspace.fm ネタ投稿"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}

